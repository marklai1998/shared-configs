{
  "name": "@marklai/shared-config-commitlint",
  "version": "1.0.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/marklai1998/shared-configs.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsdown --format esm"
  },
  "dependencies": {
    "@commitlint/config-conventional": "21.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "tsdown": "0.22.4",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "@commitlint/cli": "^20.0.0 || ^21.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
