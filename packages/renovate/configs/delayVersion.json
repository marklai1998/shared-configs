{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Wait 3 days before updating external dependencies",
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "minimumReleaseAge": "3 days"
    }
  ]
}
